@page
@using Kasi_Room_Network___KRN.Constants
@model RegisterModel
@{
    ViewData["Title"] = "Join KRN";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container px-1">

    <div class="row justify-content-center">

        <div class="col-lg-6 col-md-8">

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <h1 class="fw-bold">Join Kasi Room Network</h1>
                        <p class="text-muted mb-0">
                            Find rooms. Connect with landlords.
                        </p>
                    </div>

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"
                         role="alert">
                    </div>

                    <form id="registerForm"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   autocomplete="username" />

                            <span asp-validation-for="Input.Email"
                                  class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Role"
                                   class="form-label">
                                I want to join as
                            </label>

                            <select asp-for="Input.Role"
                                    class="form-select">

                                @foreach (var role in Enum.GetValues(typeof(Roles))
                                                                .Cast<Roles>()
                                                                .Where(r => r != Roles.Admin))
                                {
                                    <option value="@role">@role</option>
                                }

                            </select>

                            <span asp-validation-for="Input.Role"
                                  class="text-danger"></span>
                        </div>                       

                        <div class="mb-3">
                            <label asp-for="Input.Password"
                                   class="form-label"></label>

                            <input asp-for="Input.Password"
                                   class="form-control"
                                   autocomplete="new-password" />

                            <div class="form-text">
                                Use at least 8 characters.
                            </div>

                            <span asp-validation-for="Input.Password"
                                  class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword"
                                   class="form-label"></label>

                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control"
                                   autocomplete="new-password" />

                            <span asp-validation-for="Input.ConfirmPassword"
                                  class="text-danger"></span>
                        </div>

                        <div class="alert alert-info py-2 small">
                            <strong>Password Requirements</strong>
                            <ul class="mb-0 mt-1">
                                <li>Minimum 8 characters</li>
                                <li>At least one uppercase letter (A-Z)</li>
                                <li>At least one lowercase letter (a-z)</li>
                                <li>At least one number (0-9)</li>
                                <li>At least one special character (!@@#$%^&* etc.)</li>
                            </ul>
                        </div>

                        <button id="registerSubmit"
                                type="submit"
                                class="btn btn-success w-100">
                            Create Account
                        </button>

                    </form>

                    <div class="text-center m-3">
                        <p class="mb-0">
                            Already have an account?
                            <a asp-page="./Login"
                               asp-route-returnUrl="@Model.ReturnUrl"
                               class="fw-semibold">
                                Sign In
                            </a>
                        </p>
                    </div>

                    <hr />

                    <div class="text-center small text-muted">
                        By creating an account you can search rooms,
                        contact landlords and manage listings on KRN.
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}