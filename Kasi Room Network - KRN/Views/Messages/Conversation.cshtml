@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Messaging.MessageViewModel>

@{
    ViewData["Title"] = "Conversation";
    var conversationId = ViewBag.ConversationId;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<h2>Conversation</h2>
<div class="card">

    <div class="card-body" style="max-height:400px; overflow-y:auto;">

        @foreach (var msg in Model)
        {
            var isMine = msg.SenderId == currentUserId;

            <div class="mb-2 text-@(isMine ? "end" : "start")">

                <span class="badge @(isMine ? "bg-primary" : "bg-secondary")">
                    @msg.MessageText
                </span>

                <div>
                    <small class="text-muted">
                        @msg.CreatedAt.ToString("g")
                    </small>
                </div>

            </div>
        }

    </div>

</div>
<form asp-action="Send" method="post" class="mt-3">

   @*  @{
        var conversationId = Model.FirstOrDefault()?.ConversationId;
    } *@

    <input type="hidden" name="ConversationId" value="@conversationId" />

    <div class="input-group">

        <input type="text"
               name="MessageText"
               class="form-control"
               placeholder="Type a message..."
               required />

        <button type="submit" class="btn btn-primary">
            Send
        </button>

    </div>

</form>
