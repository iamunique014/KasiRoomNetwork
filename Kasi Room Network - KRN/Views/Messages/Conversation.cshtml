@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Messaging.MessageViewModel>

@{
    ViewData["Title"] = "Conversation";
    var conversationId = ViewBag.ConversationId;
}

<div class="container p-0">

    <div class="card m-0 shadow-sm">
        
        <div class="card-header d-flex align-items-center">
            <a class="btn btn-outline-primary me-2"
               asp-action="Inbox">

                <i class="bi bi-arrow-left me-1"></i>

            </a>
            <h5 class="mb-0">Conversation</h5>
        </div>
        
        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <p class="mb-1">No messages yet.</p>
                    <small>Start the conversation below.</small>
                </div>
            }
            else
            {
                @foreach (var msg in Model)
                {
                    <div class="d-flex @(msg.IsMyMessage ? "justify-content-end" : "justify-content-start") mb-3">

                        <div style="max-width:80%;">

                            <div class="p-3 rounded-3 @(msg.IsMyMessage
                                                                 ? "bg-primary text-white"
                                                                 : "bg-light border")">

                                @msg.MessageText

                            </div>

                            <div class="mt-1 @(msg.IsMyMessage ? "text-end" : "text-start")">
                                <small class="text-muted">
                                    @msg.CreatedAt.ToString("g")
                                </small>
                            </div>

                        </div>

                    </div>
                        }
            }

        </div>

        <div class="card-footer">

            <form asp-action="Send" method="post">

                <input type="hidden"
                       name="ConversationId"
                       value="@conversationId" />

                <div class="input-group">

                    <input type="text"
                           name="MessageText"
                           class="form-control"
                           placeholder="Type a message..."
                           maxlength="1000"
                           required />

                    <button type="submit"
                            class="btn btn-primary">
                        Send
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>