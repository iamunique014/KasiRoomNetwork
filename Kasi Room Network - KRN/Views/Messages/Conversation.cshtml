@using KasiRoomNetwork.Common.ViewModel.Messaging
@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Messaging.MessageViewModel>

@{
    ViewData["Title"] = "Conversation";
    var conversationId = ViewBag.ConversationId;
    var header = ViewBag.ConversationHeader as ConversationViewModel;
}

@section styles {
    <link rel="stylesheet" href="~/css/conversation.css" />
}

@if (header == null)
{
    <div class="container mt-4">
        <div class="alert alert-danger">
            Conversation could not be loaded.
        </div>
    </div>

    return;
}

<div class="container p-0">

    <div class="card shadow-sm conversation-card">

        <div class="conversation-header">

            <a asp-action="Index"
               asp-route-returnUrl="@ViewBag.ReturnUrl"
               class="back-btn">
                <i class="bi bi-arrow-left"></i>
            </a>

            <a asp-action="ListingDetails"
               asp-controller="Listing"
               asp-route-listingId="@header.ListingId">

                @if (!string.IsNullOrWhiteSpace(header.PrimaryPhoto))
                {
                    <img src="@header.PrimaryPhoto"
                         class="conversation-thumb"
                         alt="@header.ListingTitle" />
                }

            </a>

            <a asp-action="ListingDetails"
               asp-controller="Listing"
               asp-route-listingId="@header.ListingId"
               class="text-decoration-none">

                <div class="conversation-info">
                    <h6>@header.ListingTitle</h6>
                    <small>@header.OtherUserName</small>
                </div>

            </a>

        </div>

        <div class="card-body messages-container"
             id="messagesContainer">

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">

                    <i class="bi bi-chat-dots fs-1"></i>

                    <p class="mt-3 mb-1">
                        No messages yet
                    </p>

                    <small>
                        Start the conversation below.
                    </small>

                </div>
            }
            else
            {
                @foreach (var msg in Model)
                {
                    <div class="message-row @(msg.IsMyMessage ? "mine" : "theirs")">

                        <div class="message-bubble @(msg.IsMyMessage
                                                                                      ? "message-mine"
                                                                                      : "message-theirs")">

                    @msg.MessageText

                        </div>

                        <div class="message-time">

                    @{
                                var now = DateTime.Now;
                                var created = msg.CreatedAt;

                                if (created.Date == now.Date)
                                {
                                    @:Today @created.ToString("HH:mm")
                                }
                                else if (created.Date == now.Date.AddDays(-1))
                                {
                                    @:Yesterday @created.ToString("HH:mm")
                                }
                                else
                                {
                                    @created.ToString("dd MMM yyyy HH:mm")
                                }
                            }

                        </div>

                    </div>
                }
            }

        </div>

        <div class="card-footer">

            <form asp-action="Send" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-2"></div>

                <input type="hidden"
                       name="ConversationId"
                       value="@conversationId" />

                <div class="input-group">

                    <input type="text"
                           name="MessageText"
                           class="form-control"
                           placeholder="Type a message..."
                           maxlength="1000"
                           autocomplete="off"
                           required />

                    <button type="submit"
                            class="btn btn-primary">

                        Send

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const container =
                document.getElementById("messagesContainer");

            if (container) {
                container.scrollTop = container.scrollHeight;
            }

        });
    </script>
}