@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Messaging.ConversationViewModel>

@{
    ViewData["Title"] = "Inbox";
}

<h2>Inbox</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No messages yet.
    </div>
}
else
{
    <div class="list-group">

        @foreach (var conversation in Model)
        {

            <a asp-controller="Messages"
               asp-action="Conversation"
               asp-route-conversationId="@conversation.ConversationId"
               class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between">

                    <strong>@conversation.ListingTitle</strong>

                    @* <small>
                        @conversation.LastMessageAt.ToString("g")
                    </small> *@

                </div>
                <div class="d-flex justify-content-between">

                    <small>@conversation.OtherUserName</small>

                    
                    

                    <small>
                        @conversation.LastMessageAt.ToString("g")
                    </small>

                </div>

                <div class="d-flex justify-content-between">

                    @{
                        var preview = conversation.LastMessage;

                        if (!string.IsNullOrWhiteSpace(preview) &&
                        preview.Length > 20)
                        {
                            preview = preview.Substring(0, 20) + "...";
                        }
                    }

                    <div class="text-muted">
                        @preview
                    </div>

                    @if (conversation.UnreadCount > 0)
                    {
                        <span class="badge bg-success">
                            @conversation.UnreadCount
                        </span>
                    }

                </div>

            </a>
        }

    </div>
}