@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Landlord.LandlordListingViewModel>
@{
    ViewData["Title"] = "My Properties";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-3">My Properties</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <span>@TempData["SuccessMessage"]</span>
            <a asp-controller="Listing" asp-action="CreateListing" class="btn btn-success btn-sm">
                Add Room (Listing)
            </a>
        </div>
    }

    <div class="d-flex justify-content-end mb-3">
        <a asp-controller="Listing" asp-action="CreateListing" class="btn btn-outline-primary">
            Add Room (Listing)
        </a>
    </div>
  
    @if (Model.Any())
    {
        <div class="row">

            @foreach (var listing in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">

                        @* <div class="card-footer bg-white">
                            @if (Model.IsVerified)
                            {
                                SU
                            }
                        </div> *@

                        @if (!string.IsNullOrEmpty(listing.PrimaryPhoto))
                        {
                            <img src="@listing.PrimaryPhoto"
                                 class="card-img-top"
                                 style="height: 180px; object-fit: cover;"
                                 alt="Listing image" />
                        }

                        <div class="card-body">
                            <h5 class="card-title">@listing.Title</h5>
                            <p class="card-text">
                                @listing.Suburb, @listing.City<br />
                                <span class="fw-bold text-success fs-5">
                                    R @listing.Price per month
                                </span>
                            </p>
                        </div>

                        <div class="card-footer bg-white">
                            <a asp-action="ReviewListingDetails"
                               asp-route-id="@listing.ListingId"
                               class="btn btn-outline-primary w-100">
                                View Details
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No Rooms found.
        </div>
    }
</div>
