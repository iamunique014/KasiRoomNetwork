@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Landlord.LandlordListingViewModel>

@{
    ViewData["Title"] = "My Rooms";
}

@section styles
{
    <link rel="stylesheet" href="~/css/listing.css"/>
}

<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">

    <!-- Success Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex align-items-start justify-content-between gap-2 mb-1 flex-wrap">
            <div>
                <h1 class="h3 mb-1 fw-bold">My Rooms</h1>
                <p class="text-muted mb-0">Manage your room listings and availability</p>
            </div>
            <a asp-controller="Property"
               asp-action="MyProperties"
               asp-route-mode="addlisting"
               class="btn btn-primary rounded-pill px-4 shadow-sm d-none d-sm-inline-block">
                <i class="bi bi-plus-lg me-2"></i>Add Room
            </a>
        </div>
    </div>

    <!-- Mobile Add Room Button -->
    <div class="d-grid gap-2 mb-4 d-sm-none">
        <a asp-controller="Property"
           asp-action="MyProperties"
           asp-route-mode="addlisting"
           class="btn btn-primary rounded-pill shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Add Room
        </a>
    </div>

    @if (Model.Any())
    {
        <!-- Listings Grid -->
        <div class="row g-3">
            @foreach (var listing in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100 transition-all">
                        
                        <!-- Listing Image -->
                        <div class="position-relative" style="height: 200px; overflow: hidden;">
                            <img src="@(string.IsNullOrEmpty(listing.PrimaryPhoto)
                                        ? "/images/no-image.png"
                                        : listing.PrimaryPhoto)"
                                 class="w-100 h-100"
                                 style="object-fit: cover;"
                                 alt="@listing.Title" />
                            
                            <!-- Status Badges Overlay -->
                            <div class="position-absolute top-0 start-0 m-3 d-flex flex-column gap-2">
                                <span class="badge @(listing.IsVerified ? "bg-success" : "bg-warning text-dark") rounded-pill px-3 py-2 shadow-sm">
                                    <i class="bi @(listing.IsVerified ? "bi-patch-check-fill" : "bi-clock-history") me-1"></i>
                                    @(listing.IsVerified ? "Verified" : "Pending")
                                </span>
                                <span class="badge @(listing.IsAvailable ? "bg-info" : "bg-secondary") rounded-pill px-3 py-2 shadow-sm">
                                    <i class="bi @(listing.IsAvailable ? "bi-check-circle-fill" : "bi-dash-circle-fill") me-1"></i>
                                    @(listing.IsAvailable ? @listing.AvailableUnits + " Available" : "Occupied")
                                </span>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column p-4">
                            
                            <!-- Title & Price -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0 text-dark">@listing.Title</h5>
                            </div>
                            
                            <h4 class="fw-bold text-primary mb-3">
                                R @listing.Price<small class="text-muted fw-normal fs-6">/month</small>
                            </h4>

                            <!-- Location -->
                            <p class="text-muted small mb-3">
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                @listing.Suburb, @listing.City
                            </p>

                            <!-- Action Buttons -->
                            <div class="mt-auto">
                                <div class="d-grid gap-2">
                                    <a asp-controller="Listing" asp-action="MyListingDetails"
                                       asp-route-listingId="@listing.ListingId"
                                       class="btn btn-outline-primary rounded-pill">
                                        <i class="bi bi-eye me-1"></i>View Details
                                    </a>
                                    
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <a asp-controller="Listing" asp-action="EditListing"
                                               asp-route-listingId="@listing.ListingId"
                                               class="btn btn-success rounded-pill w-100">
                                                <i class="bi bi-pencil-square me-1"></i>Edit
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a asp-controller="Listing" asp-action="ManageListingPhotos"
                                               asp-route-listingId="@listing.ListingId"
                                               class="btn btn-outline-secondary rounded-pill w-100">
                                                <i class="bi bi-images me-1"></i>Photos
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card border-0 bg-light rounded-3 shadow-sm text-center py-5 px-3">
            <div class="card-body">
                <div class="bg-white p-3 rounded-circle d-inline-block mb-3 shadow-sm">
                    <i class="bi bi-house-door text-muted" style="font-size: 3rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">No Rooms Listed</h5>
                <p class="text-muted mb-4">You haven't added any room listings yet. Start by selecting a property.</p>
                <a asp-controller="Property"
                   asp-action="MyProperties"
                   asp-route-mode="addlisting"
                   class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-plus-lg me-2"></i>Add Your First Room
                </a>
            </div>
        </div>
    }
</div>
