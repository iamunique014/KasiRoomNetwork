@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Landlord.LandlordListingViewModel>
@{
    ViewData["Title"] = "My Rooms";
}

<div class="container mt-4">
  
    @if (Model.Any())
    {
        <div class="row">

            @foreach (var listing in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">

                        @* <div class="card-footer bg-white">
                            @if (Model.IsVerified)
                            {
                                SU
                            }
                        </div> *@

                        @if (!string.IsNullOrEmpty(listing.PrimaryPhoto))
                        {
                            <img src="@listing.PrimaryPhoto"
                                 class="card-img-top"
                                 style="height: 180px; object-fit: cover;"
                                 alt="Listing image" />
                        }

                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="badge @(listing.IsVerified ? "bg-success" : "bg-warning text-dark")">
                                    @(listing.IsVerified ? "Verified" : "Pending Verification")
                                </span>
                                <span class="badge @(listing.IsAvailable ? "bg-primary" : "bg-secondary")">
                                    @(listing.IsAvailable ? "Available" : "Unavailable")
                                </span>
                            </div>
                            <h5 class="card-title">@listing.Title</h5>
                            <p class="card-text">
                                @listing.Suburb, @listing.City<br />
                                <span class="fw-bold text-success fs-5">
                                    R @listing.Price per month
                                </span>
                            </p>
                        </div>

                        <div class="card-footer bg-white">
                            <a asp-controller="Listing" asp-action="ListingDetails"
                               asp-route-listingId="@listing.ListingId"
                               class="btn btn-outline-primary w-100 mb-2">
                                View Details
                            </a>
                            <a asp-controller="Listing" asp-action="EditListing"
                               asp-route-listingId="@listing.ListingId"
                               class="btn btn-success w-100 mb-2">
                                Edit Listing
                            </a>
                            <a asp-controller="Listing" asp-action="ManageListingPhotos"
                               asp-route-listingId="@listing.ListingId"
                               class="btn btn-outline-secondary w-100">
                                Manage Photos
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No Rooms found.
        </div>
    }
</div>
