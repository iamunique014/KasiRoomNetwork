@{
    ViewData["Title"] = "KRN - Landlord";
    int UnreadMessages = ViewBag.UnreadCount ?? 0;
}

<div class="container mt-5 text-center">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }


    <div class="card shadow-sm mb-3">
        <div class="card-body">

            <h6 class="fw-bold mb-2">
                Messages 
                @if (UnreadMessages > 0)
                {
                    <span class="badge bg-success ms-2">
                        @UnreadMessages
                    </span>
                }
            </h6>

            @if (UnreadMessages > 0)
            {
                <p class="mb-2">
                    You have 
                    <span class="badge bg-success">
                        @UnreadMessages
                    </span>
                    new message(s)
                </p>

                <a href="/Messages/Inbox" class="btn btn-primary btn-sm w-100">
                    View Messages
                </a>
            }
            else
            {
                <p class="text-muted mb-2">
                    No new messages
                </p>

                <a href="/Messages/Inbox" class="btn btn-outline-secondary btn-sm w-100">
                    Open Inbox
                </a>
            }

        </div>
    </div>

    <div class="row g-3">

        <div class="col-6">
            <a href="/Property/CreateProperty" class="text-decoration-none">
                <div class="border rounded p-3 h-100">
                    <p class="mb-0 fw-semibold">ADD PROPERTY</p>
                </div>
            </a>
        </div>

        <div class="col-6">
            <a href="/Listing/CreateListing" class="text-decoration-none">
                <div class="border rounded p-3 h-100">
                    <p class="mb-0 fw-semibold">POST A ROOM</p>
                </div>
            </a>
        </div>

        <div class="col-6">
            <a href="/Landlord/MyRooms" class="text-decoration-none">
                <div class="border rounded p-3 h-100">
                    <p class="mb-0 fw-semibold">MY ROOMS</p>
                </div>
            </a>
        </div>

        @* <div class="col-6">
            <div class="border rounded p-3 h-100">
                <div class="fs-3"></div>
                <p class="mb-0 fw-semibold">
                    Tenants
                </p>
            </div>
        </div>

        <div class="col-6">
            <div class="border rounded p-3 h-100">
                <div class="fs-3"></div>
                <p class="mb-0 fw-semibold">
                    Admin Approved Listings
                </p>
            </div>
        </div> *@

    </div>
</div>