@{
    ViewData["Title"] = "Post a Room";
}

<div class="container mt-5 text-center">

    <h2 class="fw-bold mb-3">
        Post Your Room on Kasi Room Network
    </h2>

    <p class="text-muted mb-4">
        To keep our community safe, only registered
        landlords can post rooms.
    </p>

    <div class="row justify-content-center mb-4">
        <div class="col-10 col-md-6">
            <div class="border rounded p-3 mb-2">
                1️⃣ Create an account (free)
            </div>
            <div class="border rounded p-3 mb-2">
                2️⃣ Add room details & photos
            </div>
            <div class="border rounded p-3">
                3️⃣ Get verified & receive messages
            </div>
        </div>
    </div>

    <a href="/Identity/Account/Login" class="btn btn-primary btn-lg w-100 mb-2">Continue</a>


    <a href="/" class="btn btn-outline-secondary w-100">
        Back to Home
    </a>

</div>

