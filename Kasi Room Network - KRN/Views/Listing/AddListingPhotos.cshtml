@{
    ViewData["Title"] = "Add Photos";
    var listingId = ViewBag.ListingId;
}

<div class="container mt-4">

    <p class="text-muted mb-2">Step 2 of 2: Add photos</p>

    <h2 class="mb-2">Add Room Photos</h2>
    <p class="text-muted mb-4">
        Photos help people trust your listing and get more views
    </p>

    <form asp-action="AddListingPhotos" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
        <input type="hidden" name="listingId" value="@listingId" />
        @if (TempData["PhotoUploaded"] != null)
        {
            <div class="alert alert-success">
                @TempData["PhotoUploaded"]
            </div>
        }
        <div class="card">
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label">Upload Photo</label>
                    @if ((int)ViewBag.PhotoCount > 0)
                    {
                        <p class="text-muted">
                            @ViewBag.PhotoCount photo(s) uploaded
                        </p>
                    }
                    else
                    {
                        <p class="text-muted">
                            No photos uploaded yet.
                        </p>
                    }
                    <input type="file" name="photo" class="form-control" accept="image/*" required />
                </div>

                <div class="form-check mb-3">
                    <input type="checkbox" name="isPrimary" class="form-check-input" />
                    <label class="form-check-label">
                        Make this the main photo
                    </label>
                    <small class="text-muted d-block">
                        This photo will show first when people search
                    </small>
                </div>

                <button type="submit" class="btn btn-success">
                    Upload
                </button>

                @if (ViewBag.PhotoCount > 0)
                {
                    <a asp-action="ListingSubmitted" asp-route-id="@listingId" class="btn btn-primary ms-2">
                        Finish & Submit
                    </a>
                }
                else
                {
                    <span data-bs-toggle="tooltip"
                          data-bs-placement="top"
                          title="Please add a photo to continue.">
                        <button class="btn btn-secondary ms-2" disabled>
                            Finish & Submit
                        </button>
                    </span>
                }

            </div>
        </div>
    </form>

</div>


