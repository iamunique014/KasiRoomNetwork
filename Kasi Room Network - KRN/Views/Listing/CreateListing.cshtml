@model KasiRoomNetwork.Common.ViewModel.Listings.CreateListingViewModel

@{
    ViewData["Title"] = "Post a Room";
}

<div class="container mt-4">
    <p class="text-muted mb-2">Step 1 of 2: Add Room Details</p>

    <h2 class="fw-bold">Post a Room</h2>
    <p class="text-muted">Fill in the details below to list your room.</p>

    <form asp-action="CreateListing" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
        <input type="hidden" asp-for="PropertyId"/>
        <!-- BASIC INFO -->
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Room Details</h5>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Room title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Single room near mine" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Monthly price (R)</label>
                    <input asp-for="Price" class="form-control" />
                    <small class="text-muted">Price is per month</small>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-2">
                    <label asp-for="Description" class="form-label">Description</label>

                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the room, rules, bathroom, electricity, etc."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

            </div>
        </div>

        <button type="submit" class="btn btn-success btn-lg w-100">Post Room</button>

        <p class="text-muted small mt-2 text-center">
            Your listing will be reviewed before going live
        </p>
    </form>

</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
