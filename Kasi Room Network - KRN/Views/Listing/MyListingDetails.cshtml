@model KasiRoomNetwork.Common.ViewModel.Listings.ListingDetailsViewModel

@section styles
{
    <link rel="stylesheet" href="~/css/Property-details.css"/>
}

@functions {
    private static string GetPhotoUrl(string? photoPath)
    {
        if (string.IsNullOrWhiteSpace(photoPath))
        {
            return string.Empty;
        }

        var trimmedPath = photoPath.Trim().Replace("\\", "/");

        if (trimmedPath.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || trimmedPath.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            || trimmedPath.StartsWith("/"))
        {
            return trimmedPath;
        }

        return "/" + trimmedPath.TrimStart('~', '/');
    }
}

@{
    ViewData["Title"] = Model.Title;
    var photos = (Model.Photos ?? new List<KasiRoomNetwork.Common.ViewModel.Listings.ListingPhotoViewModel>())
        .Where(photo => !string.IsNullOrWhiteSpace(photo.PhotoPath))
        .OrderByDescending(photo => photo.IsPrimary)
        .ThenBy(photo => photo.PhotoId)
        .ToList();
}

<div class="container-fluid px-sm-3 py-3 py-sm-4">

    @* ---------------------------------------
       STATUS ALERTS
    ---------------------------------------- *@

    @if (!Model.IsVerified && !string.IsNullOrWhiteSpace(Model.VerificationNotes))
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
            <div class="d-flex">
                <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>

                <div>
                    <h5 class="mb-2">Changes Required</h5>

                    <p class="mb-2">
                        @Model.VerificationNotes
                    </p>

                    <small class="text-muted">
                        Update the listing or photos below and submit again.
                    </small>
                </div>
            </div>
        </div>
    }
    else if (!Model.IsVerified)
    {
        <div class="alert alert-warning border-0 shadow-sm rounded-4 mb-4">
            <div class="d-flex">
                <i class="bi bi-hourglass-split fs-3 me-3"></i>

                <div>
                    <h5 class="mb-2">Under Review</h5>

                    <p class="mb-0">
                        Your listing is currently being reviewed.
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">
            <div class="d-flex">
                <i class="bi bi-check-circle-fill fs-3 me-3"></i>

                <div>
                    <h5 class="mb-2">Published</h5>

                    <p class="mb-0">
                        Your listing is live and visible to tenants.
                    </p>
                </div>
            </div>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-4 shadow-sm">
            @TempData["ErrorMessage"]
        </div>
    }

    <!--Listing Header Section -->
    <div class="mb-4">
        <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
            <div>
                <h1 class="h3 mb-1 fw-bold">
                     @Model.Title
                </h1>
                <p class="text-muted mb-0">
                    <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                    @Model.Suburb, @Model.City, @Model.Province
                </p>
                <div class="d-flex flex-wrap gap-2">

                    <span class="badge @(Model.IsVerified ? "bg-success" : "bg-warning text-dark")">

                        <i class="bi bi-patch-check-fill"></i>

                            @(Model.IsVerified
                                ? "Published"
                                : "Pending Review")

                     </span>

                    <span class="badge @(Model.IsAvailable ? "bg-primary" : "bg-secondary")">

                        <i class="bi bi-house-fill"></i>

                            @(Model.IsAvailable
                                ? "Available"
                                : "Unavailable")

                    </span>

                    @if (Model.PropertyVerified)
                    {
                        <span class="badge bg-info text-dark">

                            <i class="bi bi-building-check"></i>

                                Approved Property

                        </span>
                    }

                </div>
                <div class="text-end">

                    <h2 class="text-success fw-bold mb-0">

                        R @Model.Price

                    </h2>

                    <div class="text-muted">

                        / month

                    </div>

                </div>
            </div>
        </div>
    </div>


    <!-- Listing Photos Section -->

    <div class="row g-3 mb-4">

        <div class="col-12 col-sm-6">
            @if(photos.Any())
            {
                <div id="listingCarousel"
                    class="carousel slide rounded-3 overflow-hidden shadow-sm"
                    data-bs-ride="carousel">

                    <div class="carousel-inner">

                        @for (int i = 0; i < photos.Count; i++)
                        {
                            var photo = photos[i];
                            var photoUrl = GetPhotoUrl(photo.PhotoPath);

                            <div class="carousel-item @(i == 0 ? "active" : "")">

                                <img src="@photoUrl"
                                    class="d-block w-100"
                                    style="height: 325px; object-fit: cover;"
                                    alt="@(photo.IsPrimary ? "Primary Listing photo" : "Listing photo")" />

                            </div>
                        }

                    </div>

                    @if (photos.Count > 1)
                    {
                        <button class="carousel-control-prev"
                                type="button"
                                data-bs-target="#listingCarousel"
                                data-bs-slide="prev"
                                aria-label="Previous listing photo">

                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>

                        </button>

                        <button class="carousel-control-next"
                                type="button"
                                data-bs-target="#listingCarousel"
                                data-bs-slide="next"
                                aria-label="Next listing photo">

                            <span class="carousel-control-next-icon" aria-hidden="true"></span>

                        </button>
                    }

                
                    <div class="position-absolute bottom-0 start-0 end-0 p-2">
                        <a asp-controller="Listing"
                            asp-action="ManageListingPhotos"
                            asp-route-listingId="@Model.ListingId"
                            class="btn btn-sm btn-light">
                            <i class="bi bi-pencil me-1"></i>
                            Manage Photos
                        </a>
                    </div>
                  

                </div>
            }
            else
            {
                <div class="card border-0 bg-light rounded-3 mb-4 shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-image text-muted mb-3" style="font-size: 3rem; display: block;"></i>
                        <p class="text-muted mb-3">No listing photos uploaded yet.</p>

                       
                        <a asp-controller="Listing"
                            asp-action="AddListingPhotos"
                            asp-route-listingId="@Model.ListingId"
                            class="btn btn-primary">
                                <i class="bi bi-cloud-upload me-2"></i>
                                Upload Photos
                        </a>
                        
                    </div>
                </div>
            }
        </div>
                
        <div class="col-12 col-sm-6 d-none d-sm-block">
            <!-- Listing Summary Card -->
            <div class="card border-0 shadow-sm rounded-3 mb-4">

                <div class="card-body p-4">

                    <h5 class="fw-bold mb-3 text-dark">
                        <i class="bi bi-info-circle me-2 text-info"></i>
                        Listing Information
                    </h5>

                    <div class="row g-3">

                        <div class="col-12">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-house text-primary me-3 mt-1"></i>
                                <div>
                                    <p class="small text-muted mb-1">Title</p>
                                    <p class="mb-0 fw-semibold">@Model.Title</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-door-closed text-primary me-3 mt-1"></i>
                                <div>
                                    <p class="small text-muted mb-1">Total Rooms</p>
                                    <p class="mb-0 fw-semibold">@Model.TotalRooms</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-geo-alt text-primary me-3 mt-1"></i>
                                <div>
                                    <p class="small text-muted mb-1">Location</p>
                                    <p class="mb-0 fw-semibold">@Model.Suburb, @Model.City</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-calendar-event text-primary me-3 mt-1"></i>
                                <div>
                                    <p class="small text-muted mb-1">Created</p>
                                    <p class="mb-0 fw-semibold">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                                </div>
                            </div>
                        </div>

                        <!-- LISTING INFO -->

                        <div class="card shadow-sm border-0 rounded-4">

                            <div class="card-header bg-white">

                                <h5 class="mb-0">

                                    Listing Summary

                                </h5>

                            </div>

                            <div class="card-body">

                                <div class="d-flex justify-content-between mb-3">

                                    <span class="text-muted">
                                        Created
                                    </span>

                                    <strong>
                                        @Model.CreatedAt.ToString("dd MMM yyyy")
                                    </strong>

                                </div>

                                @if (Model.IsVerified)
                                {
                                    <div class="d-flex justify-content-between mb-3">

                                        <span class="text-muted">
                                            Approved
                                        </span>

                                        <strong>
                                            @Model.VerifiedOn.ToString("dd MMM yyyy")
                                        </strong>

                                    </div>
                                }
                            </div>

                        </div>
                    </div>

                </div>

            </div>
        </div>
            
    </div>

    <!-- Landlord Action Hub -->
    <div class="mb-4">
        <h5 class="fw-bold mb-3 text-dark">
            <i class="bi bi-tools me-2 text-primary"></i>
            Manage This Listing
        </h5>

        <div class="row g-3">

            <!-- Edit Listing Info Card -->
            <div class="col-12 col-sm-6">
                <a asp-controller="Listing"
                    asp-action="EditListing"
                    asp-route-listingId="@Model.ListingId"
                    class="card h-100 border-0 shadow-sm rounded-3 text-decoration-none text-dark transition-all"
                    style="cursor: pointer;">

                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i class="bi bi-pencil-square text-info" style="font-size: 2rem;"></i>
                        </div>
                        <h6 class="card-title fw-bold mb-2">Edit Listing Info</h6>
                        <p class="card-text small text-muted mb-0">
                            Update listing title, price and more.
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-top border-light p-3">
                        <span class="text-primary small fw-semibold">
                            Edit now <i class="bi bi-arrow-right ms-1"></i>
                        </span>
                    </div>

                </a>
            </div>

            <!-- Manage Photos Card -->
            <div class="col-12 col-sm-6">
                <a asp-controller="Listing"
                    asp-action="ManageListingPhotos"
                    asp-route-listingId="@Model.ListingId"
                    class="card h-100 border-0 shadow-sm rounded-3 text-decoration-none text-dark transition-all"
                    style="cursor: pointer;">

                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i class="bi bi-images text-warning" style="font-size: 2rem;"></i>
                        </div>
                        <h6 class="card-title fw-bold mb-2">Manage Photos</h6>
                        <p class="card-text small text-muted mb-0">
                            Upload, delete, or set primary photo
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-top border-light p-3">
                        <span class="text-primary small fw-semibold">
                            Manage <i class="bi bi-arrow-right ms-1"></i>
                        </span>
                    </div>

                 </a>
            </div>

        </div>
    </div>




   <!-- DESCRIPTION -->

<div class="card shadow-sm border-0 rounded-4 mt-4">

    <div class="card-header bg-white border-0">

        <h5 class="mb-0">
            <i class="bi bi-card-text me-2"></i>
            Description
        </h5>

    </div>

    <div class="card-body">

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="mb-0" style="white-space:pre-line;">
                @Model.Description
            </p>
        }
        else
        {
            <p class="text-muted mb-0">
                No description has been added.
            </p>
        }

    </div>

</div>


<!-- Amenities Section -->
    @if (Model.Amenities != null && Model.Amenities.Any())
    {
        <div class="mb-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-star-fill me-2 text-warning"></i>
                Amenities
            </h5>

            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-body p-4">

                    @foreach (var categoryGroup in Model.Amenities.GroupBy(a => a.Category))
                    {
                        <div class="mb-4">

                            <h6 class="fw-bold text-primary mb-2">
                                @categoryGroup.Key
                            </h6>

                            <div class="d-flex flex-wrap gap-2">

                                @foreach (var amenity in categoryGroup)
                                {
                                    <span class="badge bg-light text-dark border border-secondary p-2 rounded-2">
                                        <i class="bi bi-check-circle-fill text-success me-1"></i>
                                        @amenity.Name
                                    </span>
                                }

                            </div>

                        </div>
                    }
                    <div class="border-top pt-3 mt-3">
                        <a asp-controller="Property"
                            asp-action="PropertyDetails"
                            asp-route-propertyId="@Model.PropertyId"
                            class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-building me-2"></i>
                            Open Property
                        </a>
                    </div>
                </div>

            </div>
        </div>
    }



<!-- LOCATION -->

<div class="card shadow-sm border-0 rounded-4 mt-4">

    <div class="card-header bg-white border-0">

        <h5 class="mb-0">
            <i class="bi bi-geo-alt me-2"></i>
            Location
        </h5>

    </div>

    <div class="card-body">

        <div class="row g-4">

            <div class="col-md-6">

                <small class="text-muted d-block">
                    Province
                </small>

                <strong>
                    @Model.Province
                </strong>

            </div>

            <div class="col-md-6">

                <small class="text-muted d-block">
                    City
                </small>

                <strong>
                    @Model.City
                </strong>

            </div>

            <div class="col-md-6">

                <small class="text-muted d-block">
                    Suburb
                </small>

                <strong>
                    @Model.Suburb
                </strong>

            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Street))
            {
                <div class="col-md-6">

                    <small class="text-muted d-block">
                        Street
                    </small>

                    <strong>
                        @Model.Street
                    </strong>

                </div>
            }

        </div>

    </div>

</div>