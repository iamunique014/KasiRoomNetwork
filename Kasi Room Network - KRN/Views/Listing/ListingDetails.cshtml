@model KasiRoomNetwork.Common.ViewModel.Listings.ListingDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section styles{
    <link rel="stylesheet" href="~/css/listing-details.css"/>
}

<div class="container py-4" style="max-width:1100px;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm">
            @TempData["ErrorMessage"]
        </div>
    }

    <!--Hewader, Photos,  -->
    <div class="row mb-4">

        <div class="col-lg-8 mb-3 mb-lg-0">

            @if (Model.Photos != null && Model.Photos.Any())
            {
                <div id="listingCarousel"
                     class="carousel slide shadow-sm rounded overflow-hidden"
                     data-bs-ride="carousel">

                    <div class="carousel-inner">

                        @for (int i = 0; i < Model.Photos.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">

                                <img src="@Model.Photos[i].PhotoPath"
                                     class="d-block w-100 listing-photo "
                                     alt="Listing Photo">

                            </div>
                        }

                    </div>

                    @if (Model.Photos.Count > 1)
                    {
                        <button class="carousel-control-prev"
                                type="button"
                                data-bs-target="#listingCarousel"
                                data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>

                        <button class="carousel-control-next"
                                type="button"
                                data-bs-target="#listingCarousel"
                                data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }

                </div>
            }
            else
            {
                <div class="alert alert-secondary mb-4">
                    No photos available for this listing.
                </div>
            }

        </div>

        <div class="col-lg-4">

            <div class="card card-border shadow-sm border-0">
                <div class="card-body d-flex flex-column">

                    <div class="mb-2">
                        <h2 class="fw-bold mb-1">
                            @Model.Title
                        </h2>

                        <div class="text-muted">
                            <i class="bi bi-geo-alt-fill"></i>
                            @Model.Suburb, @Model.City
                        </div>
                    </div>

                    @* <div class="d-flex flex-wrap gap-2 mb-3">

                        @if (Model.IsVerified)
                        {
                            <span class="badge bg-success">
                                ✓ Verified Listing
                            </span>
                        }

                        @if (Model.PropertyVerified)
                        {
                            <span class="badge bg-primary">
                                ✓ Verified Property
                            </span>
                        }

                        @if (Model.LandlordVerified)
                        {
                            <span class="badge bg-dark">
                                ✓ Verified Landlord
                            </span>
                        }

                    </div> *@

                    <div class="border-top border-bottom py-3 my-3">

                       @*  <div class="text-muted small">
                            Monthly Rent
                        </div> *@

                        <div class="display-6 fw-bold text-success">
                            R @Model.Price.ToString("N0")
                        </div>

                        <div class="text-muted-block small">
                            per month
                        </div>

                    </div>

                    @* <div class="mb-4">

                        <div class="row text-center">

                            <div class="col">
                                <div class="fw-bold">
                                    @Model.TotalRooms
                                </div>
                                <small class="text-muted">
                                    Rooms
                                </small>
                            </div>

                            <div class="col">
                                <div class="fw-bold">
                                    @Model.PropertyType
                                </div>
                                <small class="text-muted">
                                    Type
                                </small>
                            </div>

                        </div>

                    </div> *@

                    <div class="mt-auto">

                        <div class="d-flex gap-2">

                            @if (!string.IsNullOrWhiteSpace(Model.WhatsAppNumber))
                            {
                                <a asp-controller="Messages"
                                   asp-action="WhatsAppContact"
                                   asp-route-listingId="@Model.ListingId"
                                   class="btn btn-outline-success btn-lg">

                                    <i class="bi bi-whatsapp"></i>

                                </a>
                            }

                            <a asp-controller="Messages"
                               asp-action="ContactLandlord"
                               asp-route-listingId="@Model.ListingId"
                               asp-route-landlordId="@Model.LandlordUserId"
                               class="btn btn-success btn-lg flex-grow-1">

                                Contact Landlord

                            </a>

                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>

    @if (Model.Description != null && !string.IsNullOrWhiteSpace(Model.Description))
    {
        <div class="card card-border shadow-sm mb-4">
            <div class="card-body">

                <h5 class="fw-bold mb-3">
                    About This Room
                </h5>

                <p class="mb-0 bg-light p-3 description">
                    @Model.Description
                </p>

            </div>
        </div>
    }
    

    <!-- Amenities, Property Infomatiom -->
    

    <div class="row mb-4">
        @if (Model.Amenities != null && Model.Amenities.Any())
        {
            <div class="col-lg-6 mb-3 mb-lg-0">

                <div class="card card-border shadow-sm h-100">

                    <div class="card-body">

                        <h5 class="fw-bold mb-3">
                            Amenities
                        </h5>

                        @foreach (var amenity in Model.Amenities)
                        {
                            <span class="badge amenity-pill me-2 mb-2">
                                @amenity.Name
                            </span>
                        }

                    </div>

                </div>

            </div>
        }       

        <div class="col-lg-6">

            <div class="card shadow-sm card-border h-100">

                <div class="card-body">

                    <h5 class="fw-bold mb-3">
                        Property Information
                    </h5>

                    <div class="mb-3">
                        <small class="text-muted">Name</small>
                        <div class="fw-semibold">@Model.PropertyName</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-muted">Type</small>
                        <div class="fw-semibold">@Model.PropertyType</div>
                    </div>

                    <div>
                        <small class="text-muted">Total Rooms</small>
                        <div class="fw-semibold">@Model.TotalRooms</div>
                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Landlord -->
    <div class="card border-success card-border shadow-sm mb-4 w-100">

        <div class="card-body">

            <h5 class="fw-bold mb-2">
                @Model.FullName
            </h5>

            @if (Model.LandlordVerified)
            {
                <span class="badge bg-success verified-pill p-2 mb-3">
                    Verified Landlord
                </span>
            }

            @if (!string.IsNullOrWhiteSpace(Model.LandlordBio))
            {
                <p>
                    @Model.LandlordBio
                </p>
            }

            <div class="d-grid">

                <a asp-controller="Messages"
                   asp-action="ContactLandlord"
                   asp-route-listingId="@Model.ListingId"
                   asp-route-landlordId="@Model.LandlordUserId"
                   class="btn btn-success">

                    Contact Landlord

                </a>

            </div>

            <small class="text-muted d-block text-center mt-2">
                Chat safely without sharing your phone number.
            </small>

        </div>

    </div>

   
    <!-- Safety -->
    <div class="alert alert-warning card-border">

        <strong>Safety Tip:</strong>

        Never pay a deposit before viewing the room in person and confirming the property.

    </div>

    <!-- Back -->
    <a asp-action="SearchListings"
       class="btn btn-outline-secondary card-border w-100">

        Back To Search

    </a>

</div>