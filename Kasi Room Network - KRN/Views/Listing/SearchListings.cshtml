@model KasiRoomNetwork.Common.ViewModel.Listings.ListingSearchViewModel

@{
    ViewData["Title"] = "Find a Room";
}

<div class="container mt-4">

    <h2 class="mb-4">Find a Room</h2>

    <!-- SEARCH FORM -->
    <form asp-action="SearchListings" method="get" class="card mb-4">
        <div class="card-body">

            <!-- SIMPLE SEARCH -->
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Where are you looking?
                </label>
                <input name="City"
                       value="@Model.City"
                       class="form-control form-control-lg"
                       placeholder="City" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Max price (optional)
                </label>
                <input name="MaxPrice"
                       value="@Model.MaxPrice"
                       class="form-control form-control-lg"
                       placeholder="e.g. 1500" />
            </div>

            <!-- ADVANCED FILTERS -->
            <div class="accordion mt-3" id="advancedFilters">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#moreFilters">
                            More filters (optional)
                        </button>
                    </h2>
                    <div id="moreFilters"
                         class="accordion-collapse collapse">
                        <div class="accordion-body">

                            <div class="mb-3">
                                <label class="form-label">Province</label>
                                <input name="Province"
                                       value="@Model.Province"
                                       class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Suburb</label>
                                <input name="Suburb"
                                       value="@Model.Suburb"
                                       class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Min Price</label>
                                <input name="MinPrice"
                                       value="@Model.MinPrice"
                                       class="form-control" />
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <button type="submit"
                    class="btn btn-primary btn-lg w-100 mt-3">
                Search Rooms
            </button>

        </div>
    </form>


    <!-- RESULTS -->
    @if (Model.Results != null && Model.Results.Any())
    {
        <div class="row">

            @foreach (var listing in Model.Results)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">

                        @if (!string.IsNullOrEmpty(listing.PrimaryPhoto))
                        {
                            <img src="@listing.PrimaryPhoto"
                                 class="card-img-top"
                                 style="height: 180px; object-fit: cover;"
                                 alt="Listing image" />
                        }

                        <div class="card-body">
                            <h5 class="card-title">@listing.Title</h5>
                            <p class="card-text">
                                @listing.Suburb, @listing.City<br />
                                <span class="fw-bold text-success fs-5">
                                    R @listing.Price per month
                                </span>
                            </p>
                        </div>

                        <div class="card-footer bg-white">
                            <a asp-action="ListingDetails"
                               asp-route-id="@listing.ListingId"
                               class="btn btn-outline-primary w-100">
                                View Details
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else if (Context.Request.Query.Any())
    {
        <div class="alert alert-warning">
            No Rooms found matching your search.
        </div>
    }

</div>

