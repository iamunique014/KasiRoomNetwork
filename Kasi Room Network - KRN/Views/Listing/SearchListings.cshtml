@model KasiRoomNetwork.Common.ViewModel.Listings.ListingSearchViewModel

@{
    ViewData["Title"] = "Find a Room";
}

<div class="container">

    <form asp-action="SearchListings" method="get">
        <div class="card shadow-sm border-0 search-card mb-4">
            <div class="card-body p-4">

                <div class="mb-4">
                    <h4 class="fw-bold mb-1">
                        Find Your Next Room
                    </h4>

                    <p class="text-muted mb-0">
                        Search verified rooms across SA townships
                    </p>
                </div>

                <div class="row g-3">

                    <div class="col-md-5">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-geo-alt"></i>
                            City
                        </label>

                        <input name="City"
                               value="@Model.City"
                               class="form-control form-control-lg"
                               placeholder="e.g. Johannesburg" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-cash-stack"></i>
                            Max Price
                        </label>

                        <input name="MaxPrice"
                               value="@Model.MaxPrice"
                               class="form-control form-control-lg"
                               placeholder="R 1500" />
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit"
                                class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-search"></i>
                            Search Rooms
                        </button>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="accordion" id="advancedFilters">

                    <div class="accordion-item border-0">

                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed px-0"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#moreFilters">

                                <i class="bi bi-sliders me-2"></i>
                                Advanced Filters
                            </button>
                        </h2>

                        <div id="moreFilters"
                             class="accordion-collapse collapse">

                            <div class="accordion-body px-0 pb-0">

                                <div class="row g-3">

                                    <div class="col-md-4">
                                        <label class="form-label">
                                            Province
                                        </label>

                                        <select name="Province"
                                                class="form-select">

                                            <option value="">
                                                All Provinces
                                            </option>

                                            <option value="North West">
                                                North West
                                            </option>

                                            <option value="Eastern Cape">
                                                Eastern Cape
                                            </option>

                                            <option value="Free State">
                                                Free State
                                            </option>

                                            <option value="Gauteng">
                                                Gauteng
                                            </option>

                                            <option value="KwaZulu-Natal">
                                                KwaZulu Natal
                                            </option>

                                            <option value="Limpopo">
                                                Limpopo
                                            </option>

                                            <option value="Mpumalanga">
                                                Mpumalanga
                                            </option>

                                            <option value="Northern Cape">
                                                Northern Cape
                                            </option>

                                            <option value="Western Cape">
                                                Western Cape
                                            </option>

                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">
                                            Suburb
                                        </label>

                                        <input name="Suburb"
                                               value="@Model.Suburb"
                                               class="form-control"
                                               placeholder="Optional" />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">
                                            Min Price
                                        </label>

                                        <input name="MinPrice"
                                               value="@Model.MinPrice"
                                               class="form-control"
                                               placeholder="Optional" />
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        </div>
    </form>

    

    <!-- RESULTS -->
    @if (Model.Results != null && Model.Results.Any())
    {
        <h5 class="text-muted mb-3">
            <i class="bi bi-house-door-fill text-primary"></i>
            @Model.Results.Count Room(s) Available
        </h5>

        <div class="row">

            @foreach (var listing in Model.Results)
            {
                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow-sm listing-card">

                        <div class="listing-image-wrapper">

                            @if (!string.IsNullOrEmpty(listing.PrimaryPhoto))
                            {
                                <img src="@listing.PrimaryPhoto"
                                     class="card-img-top"
                                     alt="@listing.Title" />
                            }
                            else
                            {
                                <img src="~/images/no-image.jpg"
                                     class="card-img-top"
                                     alt="No Image Available" />
                            }

                            @if(listing.IsNew)
                            {
                                <div class="verified-badge">
                                    <i class="bi bi-patch-check-fill"></i>
                                    NEW
                                </div>
                            }
                           

                        </div>

                        <div class="card-body p-3">

                            <div class="listing-price mb-2">
                                R @listing.Price.ToString("N0")
                                <span class="listing-price-period">
                                    / month
                                </span>
                            </div>

                            <h5 class="listing-title mb-2">
                                @listing.Title
                            </h5>

                            <div class="listing-location mb-3">
                                <i class="bi bi-geo-alt-fill"></i>
                                @listing.Suburb, @listing.City
                            </div>

                            <a asp-action="ListingDetails"
                               asp-route-listingId="@listing.ListingId"
                               class="btn btn-primary w-100 listing-btn">
                                View Room
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else if (Context.Request.Query.Any())
    {
        <div class="alert alert-light border text-center py-5">
            <h4 class="fw-bold">
                No Rooms Found
            </h4>

            <p class="text-muted mb-0">
                Try a nearby suburb, city, or increase your budget.
            </p>
        </div>
    }

</div>

