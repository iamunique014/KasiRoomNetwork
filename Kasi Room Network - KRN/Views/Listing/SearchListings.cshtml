@model KasiRoomNetwork.Common.ViewModel.Listings.ListingSearchViewModel

@{
    ViewData["Title"] = "Find a Room";
}

<div class="container mt-4">

    <h2 class="fw-bold">
        Find Affordable Rooms Near You
    </h2>

    <p class="text-muted">
        Search verified rooms from local landlords.
    </p>

    <!-- SEARCH FORM -->
    <form asp-action="SearchListings" method="get" class="card mb-4">
        <div class="card-body">

            <!-- SIMPLE SEARCH -->
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Where are you looking?
                </label>
                <input name="City"
                       value="@Model.City"
                       class="form-control form-control-lg"
                       placeholder="City" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Max price (optional)
                </label>
                <input name="MaxPrice"
                       value="@Model.MaxPrice"
                       class="form-control form-control-lg"
                       placeholder="e.g. 1500" />
            </div>

            <!-- ADVANCED FILTERS -->
            <div class="accordion mt-3" id="advancedFilters">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#moreFilters">
                            More filters (optional)
                        </button>
                    </h2>
                    <div id="moreFilters"
                         class="accordion-collapse collapse">
                        <div class="accordion-body">

                            <div class="mb-3">
                                <label class="form-label">Province</label>

                                <select name="Province" class="form-select">
                                    <option value="">All Provinces</option>
                                    <option value="North West">North West</option>
                                    <option value="Eastern Cape">Eastern Cape</option>
                                    <option value="Free State">Free State</option>
                                    <option value="Gauteng">Gauteng</option>
                                    <option value="KwaZulu-Natal">Kwazulu Natal</option>
                                    <option value="Limpopo">Limpopo</option>
                                    <option value="Mpumalanga">Mpumalanga</option>
                                    <option value="Northern Cape">Northern Cape</option>                            
                                    <option value="Western Cape">Western Cape</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Suburb</label>
                                <input name="Suburb"
                                       value="@Model.Suburb"
                                       class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Min Price</label>
                                <input name="MinPrice"
                                       value="@Model.MinPrice"
                                       class="form-control" />
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <button type="submit"
                    class="btn btn-primary btn-lg w-100 mt-3">
                Search Rooms
            </button>

        </div>
    </form>


    <!-- RESULTS -->
    @if (Model.Results != null && Model.Results.Any())
    {
        <div class="row">
            <h5 class="mb-3">
                @Model.Results.Count room(s) found
            </h5>
            @foreach (var listing in Model.Results)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">

                        @if (!string.IsNullOrEmpty(listing.PrimaryPhoto))
                        {
                            <img src="@listing.PrimaryPhoto"
                                 class="card-img-top"
                                 style="height: 180px; object-fit: cover;"
                                 alt="Listing image" />
                        }

                        <div class="card-body">
                            <h5 class="card-title">@listing.Title</h5>
                            <p class="card-text">
                                @listing.Suburb, @listing.City<br />
                                <span class="fw-bold text-success fs-5">
                                    R @listing.Price per month
                                </span>
                            </p>
                        </div>

                        <div class="card-footer bg-white">
                            <a asp-action="ListingDetails"
                               asp-route-listingId="@listing.ListingId"
                               class="btn btn-outline-primary w-100">
                                View Details
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else if (Context.Request.Query.Any())
    {
        <h5 class="mb-3">
            @Model.Results.Count room(s) found
        </h5>
        <div class="alert alert-light bg-light border text-center p-4">
            <h5>No rooms found</h5>

            <p class="text-muted mb-0">
                Try a nearby suburb or increase your budget.
            </p>
        </div>
    }

</div>

