@model KasiRoomNetwork.Common.ViewModel.Listings.ManageListingPhotosViewModel

@{
    ViewData["Title"] = "Manage Listing Photos";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Manage Listing Photos</h2>
        <p class="text-muted mb-0">@Model.Title</p>
    </div>

    <!-- BACK LINK -->
    <div class="mb-3">
        <a asp-action="ListingDetails" asp-controller="Listing" asp-route-listingId="@Model.ListingId" class="btn btn-outline-secondary">
            &larr; Back to Listing Details
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">Add New Photo</h5>
            <form asp-action="UploadListingPhoto" asp-controller="Listing" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="listingId" value="@Model.ListingId" />
                <div class="mb-3">
                    <label for="photoFile" class="form-label">Photo File</label>
                    <input type="file" class="form-control" id="photoFile" name="photo" accept="image/*" required />
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="isPrimary" name="isPrimary" value="true">
                    <label class="form-check-label" for="isPrimary">
                        Set as Primary Photo
                    </label>
                </div>
                <button type="submit" class="btn btn-primary">Upload Photo</button>
            </form>
        </div>
    </div>

    <!-- PHOTOS SECTION -->
    @if (Model.Photos != null && Model.Photos.Any())
    {
        <div class="row">
            @foreach (var photo in Model.Photos)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <!-- Photo -->
                        <div class="position-relative overflow-hidden" style="height: 250px;">
                            <img src="@photo.PhotoPath"
                                 class="card-img-top w-100 h-100"
                                 style="object-fit: cover;"
                                 alt="Listing photo" />
                            
                            <!-- Primary Badge -->
                            @if (photo.IsPrimary)
                            {
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-success">Primary Photo</span>
                                </div>
                            }
                        </div>

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <p class="card-text text-muted small mb-0">
                                    Photo ID: @photo.PhotoId
                                </p>
                                
                                <div class="d-flex gap-2">
                                    @if (!photo.IsPrimary)
                                    {
                                        <form asp-action="SetPrimaryListingPhoto" asp-controller="Listing" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="listingId" value="@Model.ListingId" />
                                            <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                Make Primary
                                            </button>
                                        </form>
                                    }
                                    
                                    <form asp-action="DeleteListingPhoto" asp-controller="Listing" method="post" 
                                          onsubmit="return confirm('Are you sure you want to delete this photo?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="listingId" value="@Model.ListingId" />
                                        <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- EMPTY STATE -->
        <div class="alert alert-info text-center py-5 shadow-sm">
            <h5 class="mb-2">No photos uploaded yet.</h5>
            <p class="mb-3">Start by uploading photos to showcase your listing.</p>
            <a asp-action="AddListingPhotos" asp-controller="Listing" asp-route-listingId="@Model.ListingId" class="btn btn-primary">
                Upload Photos
            </a>
        </div>
    }

</div>
