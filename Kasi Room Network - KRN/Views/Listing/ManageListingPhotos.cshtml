@model KasiRoomNetwork.Common.ViewModel.Listings.ManageListingPhotosViewModel

@{
    ViewData["Title"] = "Manage Listing Photos";
}

@section styles
{
    <link rel="stylesheet" href="~/css/listing.css" />
}

<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">

    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <a asp-action="MyListingDetails" asp-controller="Listing" asp-route-listingId="@Model.ListingId" class="btn btn-sm btn-outline-secondary rounded-circle p-1" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="h3 mb-0 fw-bold">Manage Photos</h1>
        </div>
        <p class="text-muted ms-1">@Model.Title</p>
    </div>

    <!-- Feedback Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Upload Card -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-cloud-upload me-2 text-primary"></i>
                Add New Photo
            </h5>
            <form asp-action="UploadListingPhoto" asp-controller="Listing" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="mt-2"></div>
                <input type="hidden" name="listingId" value="@Model.ListingId" />
                
                <div class="mb-3">
                    <label for="photoFile" class="form-label fw-semibold small text-muted">Select Photo <span class="text-danger">*</span></label>
                    <input type="file" class="form-control rounded-2 border-light bg-light" id="photoFile" name="photo" accept="image/*" required />
                </div>
                
                <div class="form-check form-switch p-3 bg-light rounded-2 mb-4">
                    <input class="form-check-input ms-0 me-2" type="checkbox" id="isPrimary" name="isPrimary" value="true" role="switch">
                    <label class="form-check-label fw-semibold small" for="isPrimary">
                        Set as Primary Photo
                    </label>
                </div>
                
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-upload me-2"></i>Upload Photo
                </button>
            </form>
        </div>
    </div>

    <!-- Photos Grid Section -->
    <div class="mb-4">
        <h5 class="fw-bold mb-3 text-dark">
            <i class="bi bi-grid-3x3 me-2 text-info"></i>
            Current Photos
        </h5>

        @if (Model.Photos != null && Model.Photos.Any())
        {
            <div class="row g-3">
                @foreach (var photo in Model.Photos)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card border-0 shadow-sm rounded-3 h-100 photo-grid-item overflow-hidden">
                            <!-- Photo -->
                            <div class="position-relative" style="aspect-ratio: 1/1;">
                                <img src="@photo.PhotoPath"
                                     class="w-100 h-100"
                                     style="object-fit: cover;"
                                     alt="Listing photo" />
                                
                                <!-- Primary Badge -->
                                @if (photo.IsPrimary)
                                {
                                    <div class="position-absolute top-0 start-0 m-2">
                                        <span class="badge primary-badge rounded-pill px-2 py-1 small">
                                            <i class="bi bi-star-fill me-1"></i>Primary
                                        </span>
                                    </div>
                                }

                                <!-- Actions Overlay (Mobile Friendly) -->
                                <div class="position-absolute bottom-0 start-0 end-0 p-2 bg-dark bg-opacity-50 backdrop-blur d-flex justify-content-center gap-2">
                                    @if (!photo.IsPrimary)
                                    {
                                        <form asp-action="SetPrimaryListingPhoto" asp-controller="Listing" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="listingId" value="@Model.ListingId" />
                                            <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                            <button type="submit" class="btn btn-sm btn-light rounded-circle shadow-sm" title="Make Primary" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-star text-warning"></i>
                                            </button>
                                        </form>
                                    }
                                    
                                    <form asp-action="DeleteListingPhoto" asp-controller="Listing" method="post" 
                                          onsubmit="return confirm('Are you sure you want to delete this photo?');" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="listingId" value="@Model.ListingId" />
                                        <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                        <button type="submit" class="btn btn-sm btn-danger rounded-circle shadow-sm" title="Delete" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-3 bg-light text-center py-5">
                <div class="card-body">
                    <div class="bg-white p-3 rounded-circle d-inline-block mb-3 shadow-sm">
                        <i class="bi bi-images fs-1 text-muted"></i>
                    </div>
                    <h5 class="fw-bold mb-2">No photos yet</h5>
                    <p class="text-muted mb-0">Upload photos to showcase your listing to potential tenants.</p>
                </div>
            </div>
        }
    </div>

</div>
