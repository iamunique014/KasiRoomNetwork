@model KasiRoomNetwork.Common.ViewModel.Properties.EditPropertyAmenitiesViewModel

@{
    ViewData["Title"] = "Edit Amenities";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Edit Amenities</h2>
    </div>

    <form asp-action="EditPropertyAmenities" method="post">

        <input asp-for="PropertyId" type="hidden" />

        @foreach (var category in Model.Amenities.GroupBy(a => a.Category).OrderBy(g => g.Key))
        {
            <div class="card mb-4">

                <div class="card-header">
                    <strong>@category.Key</strong>
                </div>

                <div class="card-body">

                    @foreach (var amenity in category)
                    {
                        var index = Model.Amenities.IndexOf(amenity);

                        <div class="form-check mb-2">

                            <input type="hidden"
                                   asp-for="Amenities[index].AmenityId" />

                            <input type="hidden"
                                   asp-for="Amenities[index].Name" />

                            <input type="hidden"
                                   asp-for="Amenities[index].Category" />

                            <input type="hidden"
                                   asp-for="Amenities[index].Icon" />

                            <input class="form-check-input"
                                   asp-for="Amenities[index].IsSelected" />

                            <label class="form-check-label">
                                @amenity.Name
                            </label>

                        </div>
                    }

                </div>

            </div>
        }

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary">
                Save Changes
            </button>

            <a asp-action="PropertyDetails"
               asp-route-propertyId="@Model.PropertyId"
               class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>
