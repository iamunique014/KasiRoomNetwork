@model KasiRoomNetwork.Common.ViewModel.Properties.PropertyDetailsViewModel

@section styles
{
    <link rel="stylesheet" href="~/css/Property-details.css"/>
}

@functions {
    private static string GetPhotoUrl(string? photoPath)
    {
        if (string.IsNullOrWhiteSpace(photoPath))
        {
            return string.Empty;
        }

        var trimmedPath = photoPath.Trim().Replace("\\", "/");

        if (trimmedPath.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || trimmedPath.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            || trimmedPath.StartsWith("/"))
        {
            return trimmedPath;
        }

        return "/" + trimmedPath.TrimStart('~', '/');
    }
}

@{
    ViewData["Title"] = "Property Details";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canEditProperty = User.IsInRole("Landlord") && currentUserId == Model.LandlordUserId;
    var photos = (Model.Photos ?? new List<KasiRoomNetwork.Common.ViewModel.Properties.PropertyPhotoViewModel>())
        .Where(photo => !string.IsNullOrWhiteSpace(photo.PhotoPath))
        .OrderByDescending(photo => photo.IsPrimary)
        .ThenBy(photo => photo.PhotoId)
        .ToList();
}


<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">
    @if(!Model.IsVerified && !string.IsNullOrWhiteSpace(Model.VerificationNotes))
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mx-sm-0" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @Model.VerificationNotes
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }


    @* Success Messages *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mx-sm-0" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Property Header Section -->
    <div class="mb-4">
        <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
            <div>
                <h1 class="h3 mb-1 fw-bold">
                    @Model.PropertyName
                </h1>
                <p class="text-muted mb-0">
                    <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                    @Model.Suburb, @Model.City, @Model.Province
                </p>
                <p class="text-muted small mb-0">
                    <i class="bi bi-building me-1"></i>
                    @Model.PropertyType
                </p>
            </div>
        </div>
    </div>

    <!-- Property Photos Section -->
    @if(photos.Any())
    {
        <div class="mb-4">
            <div id="propertyCarousel"
                 class="carousel slide rounded-3 overflow-hidden shadow-sm"
                 data-bs-ride="carousel">

                <div class="carousel-inner">

                    @for (int i = 0; i < photos.Count; i++)
                    {
                        var photo = photos[i];
                        var photoUrl = GetPhotoUrl(photo.PhotoPath);

                        <div class="carousel-item @(i == 0 ? "active" : "")">

                            <img src="@photoUrl"
                                 class="d-block w-100"
                                 style="height: 300px; object-fit: cover;"
                                 alt="@(photo.IsPrimary ? "Primary property photo" : "Property photo")" />

                        </div>
                    }

                </div>

                @if (photos.Count > 1)
                {
                    <button class="carousel-control-prev"
                            type="button"
                            data-bs-target="#propertyCarousel"
                            data-bs-slide="prev"
                            aria-label="Previous property photo">

                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>

                    </button>

                    <button class="carousel-control-next"
                            type="button"
                            data-bs-target="#propertyCarousel"
                            data-bs-slide="next"
                            aria-label="Next property photo">

                        <span class="carousel-control-next-icon" aria-hidden="true"></span>

                    </button>
                }

                @if (canEditProperty)
                {
                    <div class="position-absolute bottom-0 start-0 end-0 p-2">
                        <a asp-controller="Property"
                           asp-action="ManagePropertyPhotos"
                           asp-route-propertyId="@Model.PropertyId"
                           class="btn btn-sm btn-light">
                            <i class="bi bi-pencil me-1"></i>
                            Manage Photos
                        </a>
                    </div>
                }

            </div>
        </div>
        }
        else
        {
            <div class="card border-0 bg-light rounded-3 mb-4 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-image text-muted mb-3" style="font-size: 3rem; display: block;"></i>
                    <p class="text-muted mb-3">No property photos uploaded yet.</p>

                    @if (canEditProperty)
                    {
                        <a asp-controller="Property"
                           asp-action="AddPropertyPhotos"
                           asp-route-propertyId="@Model.PropertyId"
                           class="btn btn-primary">
                            <i class="bi bi-cloud-upload me-2"></i>
                            Upload Photos
                        </a>
                    }
                </div>
            </div>
        }

    <!-- Landlord Action Hub (Only visible to property owner) -->
    @if (canEditProperty)
    {
        <div class="mb-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-tools me-2 text-primary"></i>
                Manage This Property
            </h5>

            <div class="row g-3">

                <!-- Add Listing Card -->
                <div class="col-12 col-sm-6">
                    <a asp-controller="Listing"
                       asp-action="CreateListing"
                       asp-route-propertyId="@Model.PropertyId"
                       class="card h-100 border-0 shadow-sm rounded-3 text-decoration-none text-dark transition-all"
                       style="cursor: pointer;">

                        <div class="card-body p-4">
                            <div class="mb-3">
                                <i class="bi bi-plus-circle-fill text-success" style="font-size: 2rem;"></i>
                            </div>
                            <h6 class="card-title fw-bold mb-2">Add Listing</h6>
                            <p class="card-text small text-muted mb-0">
                                Create a new room listing for this property
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-top border-light p-3">
                            <span class="text-primary small fw-semibold">
                                Get started <i class="bi bi-arrow-right ms-1"></i>
                            </span>
                        </div>

                    </a>
                </div>

                <!-- Edit Property Info Card -->
                <div class="col-12 col-sm-6">
                    <a asp-controller="Property"
                       asp-action="EditProperty"
                       asp-route-propertyId="@Model.PropertyId"
                       class="card h-100 border-0 shadow-sm rounded-3 text-decoration-none text-dark transition-all"
                       style="cursor: pointer;">

                        <div class="card-body p-4">
                            <div class="mb-3">
                                <i class="bi bi-pencil-square text-info" style="font-size: 2rem;"></i>
                            </div>
                            <h6 class="card-title fw-bold mb-2">Edit Property Info</h6>
                            <p class="card-text small text-muted mb-0">
                                Update property name, type, and address
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-top border-light p-3">
                            <span class="text-primary small fw-semibold">
                                Edit now <i class="bi bi-arrow-right ms-1"></i>
                            </span>
                        </div>

                    </a>
                </div>

                <!-- Manage Photos Card -->
                <div class="col-12 col-sm-6">
                    <a asp-controller="Property"
                       asp-action="ManagePropertyPhotos"
                       asp-route-propertyId="@Model.PropertyId"
                       class="card h-100 border-0 shadow-sm rounded-3 text-decoration-none text-dark transition-all"
                       style="cursor: pointer;">

                        <div class="card-body p-4">
                            <div class="mb-3">
                                <i class="bi bi-images text-warning" style="font-size: 2rem;"></i>
                            </div>
                            <h6 class="card-title fw-bold mb-2">Manage Photos</h6>
                            <p class="card-text small text-muted mb-0">
                                Upload, delete, or set primary photo
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-top border-light p-3">
                            <span class="text-primary small fw-semibold">
                                Manage <i class="bi bi-arrow-right ms-1"></i>
                            </span>
                        </div>

                    </a>
                </div>

                <!-- Edit Amenities Card -->
                <div class="col-12 col-sm-6">
                    <a asp-controller="Property"
                       asp-action="EditPropertyAmenities"
                       asp-route-propertyId="@Model.PropertyId"
                       class="card h-100 border-0 shadow-sm rounded-3 text-decoration-none text-dark transition-all"
                       style="cursor: pointer;">

                        <div class="card-body p-4">
                            <div class="mb-3">
                                <i class="bi bi-star-fill text-danger" style="font-size: 2rem;"></i>
                            </div>
                            <h6 class="card-title fw-bold mb-2">Edit Amenities</h6>
                            <p class="card-text small text-muted mb-0">
                                Add or remove property amenities
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-top border-light p-3">
                            <span class="text-primary small fw-semibold">
                                Edit <i class="bi bi-arrow-right ms-1"></i>
                            </span>
                        </div>

                    </a>
                </div>

            </div>
        </div>
    }

    <!-- Amenities Section -->
    @if (Model.Amenities != null && Model.Amenities.Any())
    {
        <div class="mb-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-star-fill me-2 text-warning"></i>
                Amenities
            </h5>

            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-body p-4">

                    @foreach (var categoryGroup in Model.Amenities.GroupBy(a => a.Category))
                    {
                        <div class="mb-4">

                            <h6 class="fw-bold text-primary mb-2">
                                @categoryGroup.Key
                            </h6>

                            <div class="d-flex flex-wrap gap-2">

                                @foreach (var amenity in categoryGroup)
                                {
                                    <span class="badge bg-light text-dark border border-secondary p-2 rounded-2">
                                        <i class="bi bi-check-circle-fill text-success me-1"></i>
                                        @amenity.Name
                                    </span>
                                }

                            </div>

                        </div>
                    }

                    @if (canEditProperty)
                    {
                        <div class="border-top pt-3 mt-3">
                            <a asp-controller="Property"
                               asp-action="EditPropertyAmenities"
                               asp-route-propertyId="@Model.PropertyId"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i>
                                Edit Amenities
                            </a>
                        </div>
                    }

                </div>

            </div>
        </div>
    }

    <!-- Property Summary Card -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">

        <div class="card-body p-4">

            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-info-circle me-2 text-info"></i>
                Property Information
            </h5>

            <div class="row g-3">

                <div class="col-12 col-sm-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-building text-primary me-3 mt-1"></i>
                        <div>
                            <p class="small text-muted mb-1">Property Type</p>
                            <p class="mb-0 fw-semibold">@Model.PropertyType</p>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-door-closed text-primary me-3 mt-1"></i>
                        <div>
                            <p class="small text-muted mb-1">Total Rooms</p>
                            <p class="mb-0 fw-semibold">@Model.TotalRooms</p>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-geo-alt text-primary me-3 mt-1"></i>
                        <div>
                            <p class="small text-muted mb-1">Location</p>
                            <p class="mb-0 fw-semibold">@Model.Suburb, @Model.City</p>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-calendar-event text-primary me-3 mt-1"></i>
                        <div>
                            <p class="small text-muted mb-1">Created</p>
                            <p class="mb-0 fw-semibold">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>
