@model KasiRoomNetwork.Common.ViewModel.Properties.ManagePropertyPhotosViewModel

@{
    ViewData["Title"] = "Manage Property Photos";
}

@section styles
{
    <link rel="stylesheet" href="~/css/Property-details.css"/>
}

<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">

    <!-- Header Section -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <a asp-action="PropertyDetails" asp-controller="Property" asp-route-propertyId="@Model.PropertyId" class="btn btn-sm btn-outline-secondary rounded-circle p-1" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="h3 mb-0 fw-bold">Manage Photos</h1>
        </div>
        <p class="text-muted mb-0 ms-1">@Model.PropertyName</p>
    </div>

    @* Success/Error Messages *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Upload Card -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-cloud-upload me-2 text-primary"></i>
                Add New Photo
            </h5>
            
            <form asp-action="UploadPropertyPhoto" asp-controller="Property" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="mt-2"></div>
                <input type="hidden" name="propertyId" value="@Model.PropertyId" />
                
                <div class="mb-3">
                    <label for="photoFile" class="form-label fw-semibold small text-muted">Select Photo</label>
                    <input type="file" class="form-control rounded-2 border-light bg-light" id="photoFile" name="photo" accept="image/*" required />
                </div>
                
                <div class="form-check form-switch mb-4">
                    <input class="form-check-input" type="checkbox" id="isPrimary" name="isPrimary" value="true">
                    <label class="form-check-label fw-semibold small text-muted" for="isPrimary">
                        Set as Primary Photo
                    </label>
                </div>
                
                <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm">
                    <i class="bi bi-upload me-2"></i>Upload Photo
                </button>
            </form>
        </div>
    </div>

    <!-- Photos Grid Section -->
    <div class="mb-3">
        <h5 class="fw-bold mb-3 text-dark">
            <i class="bi bi-grid-3x3 me-2 text-info"></i>
            Property Gallery
        </h5>
    </div>

    @if (Model.Photos != null && Model.Photos.Any())
    {
        <div class="row g-3">
            @foreach (var photo in Model.Photos)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100 transition-all">
                        <!-- Photo Wrapper -->
                        <div class="position-relative" style="height: 200px;">
                            <img src="@photo.PhotoPath"
                                 class="w-100 h-100"
                                 style="object-fit: cover;"
                                 alt="Property photo" />
                            
                            <!-- Primary Badge -->
                            @if (photo.IsPrimary)
                            {
                                <div class="position-absolute top-0 start-0 m-2">
                                    <span class="badge bg-success shadow-sm rounded-pill">
                                        <i class="bi bi-star-fill me-1"></i>Primary
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="card-body p-3 bg-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">ID: @photo.PhotoId</span>
                                
                                <div class="d-flex gap-2">
                                    @if (!photo.IsPrimary)
                                    {
                                        <form asp-action="SetPrimaryPropertyPhoto" asp-controller="Property" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="propertyId" value="@Model.PropertyId" />
                                            <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-3" title="Make Primary">
                                                <i class="bi bi-star"></i>
                                            </button>
                                        </form>
                                    }
                                    
                                    <form asp-action="DeletePropertyPhoto" asp-controller="Property" method="post" class="m-0"
                                          onsubmit="return confirm('Are you sure you want to delete this photo?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="propertyId" value="@Model.PropertyId" />
                                        <input type="hidden" name="photoId" value="@photo.PhotoId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card border-0 bg-light rounded-3 shadow-sm text-center py-5 px-3">
            <div class="card-body">
                <i class="bi bi-images text-muted mb-3" style="font-size: 3rem; display: block;"></i>
                <h5 class="fw-bold mb-2">No photos yet</h5>
                <p class="text-muted mb-0">Upload photos to make your property stand out to potential tenants.</p>
            </div>
        </div>
    }

    <!-- Back Button for Mobile -->
    <div class="d-grid gap-2 mt-4 mb-5 d-md-none">
        <a asp-action="PropertyDetails" asp-controller="Property" asp-route-propertyId="@Model.PropertyId" class="btn btn-outline-secondary rounded-pill">
            Back to Details
        </a>
    </div>

</div>
