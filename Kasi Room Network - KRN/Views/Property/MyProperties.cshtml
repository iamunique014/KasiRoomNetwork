@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Landlord.PropertyCardViewModel>

@{
    ViewData["Title"] = "My Properties";
}

@section styles
{
    <link rel="stylesheet" href="~/css/Property-details.css"/>
}

<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">

    <!-- Success Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Page Header -->
    @if (ViewBag.Mode == "addlisting")
    {
        <div class="mb-4">
            <div class="d-flex align-items-center gap-2 mb-2">
                <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary rounded-circle p-1" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h1 class="h3 mb-0 fw-bold">Add Room Listing</h1>
            </div>
            <p class="text-muted ms-1">Select the property where you'd like to add a room.</p>
        </div>
    }
    else
    {
        <div class="mb-4">
            <div class="d-flex align-items-start justify-content-between gap-2 mb-1 flex-wrap">
                <div>
                    <h1 class="h3 mb-1 fw-bold">My Properties</h1>
                    <p class="text-muted mb-0">Manage your properties and listings</p>
                </div>
                <a asp-controller="Property"
                   asp-action="CreateProperty"
                   class="btn btn-primary rounded-pill px-4 shadow-sm d-none d-sm-inline-block">
                    <i class="bi bi-plus-lg me-2"></i>Add Property
                </a>
            </div>
        </div>
    }

    <!-- Mobile Add Property Button -->
    @if (ViewBag.Mode != "addlisting")
    {
        <div class="d-grid gap-2 mb-4 d-sm-none">
            <a asp-controller="Property"
               asp-action="CreateProperty"
               class="btn btn-primary rounded-pill shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Add Property
            </a>
        </div>
    }

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="card border-0 bg-light rounded-3 shadow-sm text-center py-5 px-3">
            <div class="card-body">
                <i class="bi bi-building text-muted mb-3" style="font-size: 3rem; display: block;"></i>
                <h5 class="fw-bold mb-2">No Properties Yet</h5>
                <p class="text-muted mb-4">Start by adding your first property to begin listing rooms.</p>
                <a asp-controller="Property"
                   asp-action="CreateProperty"
                   class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-plus-lg me-2"></i>Create Property
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Properties Grid -->
        <div class="row g-3">
            @foreach (var property in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100 transition-all">
                        
                        <!-- Property Image -->
                        <div class="position-relative" style="height: 200px; overflow: hidden;">
                            <img src="@(string.IsNullOrEmpty(property.PrimaryPhoto)
                                        ? "/images/no-image.png"
                                        : property.PrimaryPhoto)"
                                 class="w-100 h-100"
                                 style="object-fit: cover;"
                                 alt="@property.PropertyName" />
                        </div>

                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column p-4">
                            
                            <!-- Property Name -->
                            <h5 class="fw-bold mb-1 text-dark">
                                @property.PropertyName
                            </h5>

                            <!-- Property Type -->
                            <p class="text-muted small mb-2">
                                <i class="bi bi-building me-1"></i>
                                @property.PropertyType
                            </p>

                            <!-- Location -->
                            <p class="text-muted small mb-3">
                                <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                                @property.Street, @property.Suburb, @property.City
                            </p>

                            <!-- Stats -->
                            <div class="mb-3 pb-3 border-bottom">
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge bg-primary rounded-pill">
                                        <i class="bi bi-door-closed me-1"></i>@property.TotalRooms @(property.TotalRooms == 1 ? "Room" : "Rooms")
                                    </span>
                                    @* <span class="badge bg-info rounded-pill">
                                        <i class="bi bi-list-check me-1"></i>@property.TotalListings @(property.TotalListings == 1 ? "Listing" : "Listings")
                                    </span> *@
                                </div>
                            </div>

                            <!-- Created Date -->
                            <small class="text-muted mb-3">
                                <i class="bi bi-calendar-event me-1"></i>
                                Added on @property.CreatedAt.ToString("dd MMM yyyy")
                            </small>

                            <!-- Action Buttons -->
                            <div class="mt-auto d-grid gap-2">
                                @if (ViewBag.Mode == "addlisting")
                                {
                                    <a asp-controller="Listing"
                                       asp-action="CreateListing"
                                       asp-route-propertyId="@property.PropertyId"
                                       class="btn btn-success rounded-pill shadow-sm">
                                        <i class="bi bi-plus-circle me-1"></i>Add Listing
                                    </a>

                                    <a asp-controller="Property"
                                       asp-action="PropertyDetails"
                                       asp-route-propertyId="@property.PropertyId"
                                       class="btn btn-outline-primary rounded-pill">
                                        <i class="bi bi-eye me-1"></i>View Property
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Property"
                                       asp-action="PropertyDetails"
                                       asp-route-propertyId="@property.PropertyId"
                                       class="btn btn-primary rounded-pill shadow-sm">
                                        <i class="bi bi-eye me-1"></i>View Property
                                    </a>

                                    <a asp-controller="Listing"
                                       asp-action="CreateListing"
                                       asp-route-propertyId="@property.PropertyId"
                                       class="btn btn-success rounded-pill">
                                        <i class="bi bi-plus-circle me-1"></i>Add Listing
                                    </a>

                                    <form asp-action="DeleteProperty" method="post" class="mt-2" onsubmit="return confirm('Are you sure you want to delete this property? This action cannot be undone.');">
                                        <input type="hidden"
                                               name="propertyId"
                                               value="@property.PropertyId" />
                                        <button type="submit"
                                                class="btn btn-outline-danger rounded-pill w-100">
                                            <i class="bi bi-trash me-1"></i>Delete Property
                                        </button>
                                    </form>
                                }
                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>
    }

</div>
