@model List<KasiRoomNetwork.Common.ViewModel.Properties.LandlordPropertyViewModel>

@{
    ViewData["Title"] = "My Properties";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">My Properties</h2>
        <a asp-controller="Property" asp-action="CreateProperty" class="btn btn-success">Create Property</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mt-3">@TempData["SuccessMessage"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-2">No properties yet</h5>
                <p class="text-muted mb-3">Create your first property to start publishing room listings.</p>
                <a asp-controller="Property" asp-action="CreateProperty" class="btn btn-success">Create Property</a>
            </div>
        </div>
    }
    else
    {
        <div class="card mt-3">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Property</th>
                            <th>Type</th>
                            <th>Rooms</th>
                            <th>Address</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var property in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@property.PropertyName</strong><br />
                                    <small class="text-muted">ID: @property.PropertyId</small>
                                </td>
                                <td>@property.PropertyType</td>
                                <td>@property.TotalRooms</td>
                                <td>@property.Street, @property.Suburb, @property.City, @property.Province</td>
                                <td>@property.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-2">Next step</h5>
                <p class="text-muted mb-3">Add a room listing for your property so tenants can discover it.</p>
                <a asp-controller="Listing" asp-action="CreateListing" class="btn btn-success">
                    Add Room (Listing)
                </a>
                <a asp-controller="Landlord" asp-action="MyRooms" class="btn btn-outline-secondary ms-2">
                    View My Rooms
                </a>
            </div>
        </div>
    }
</div>
