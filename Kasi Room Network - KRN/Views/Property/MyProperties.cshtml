@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Landlord.PropertyCardViewModel>

@{
    ViewData["Title"] = "My Properties";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">My Properties</h2>
            <p class="text-muted mb-0">
                Manage your properties and listings
            </p>
        </div>

        <a asp-controller="Property"
           asp-action="CreateProperty"
           class="btn btn-primary">
            + Add Property
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">

                <h4 class="mb-3">No Properties Yet</h4>

                <p class="text-muted mb-4">
                    Start by adding your first property.
                </p>

                <a asp-controller="Property"
                   asp-action="CreateProperty"
                   class="btn btn-success">
                    Create Property
                </a>

            </div>
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var property in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow-sm border-0 h-100">

                        <!-- Property Image -->
                        <img src="@(string.IsNullOrEmpty(property.PrimaryPhoto)
                                                                     ? "/images/no-image.png"
                                                                     : property.PrimaryPhoto)"
                     class="card-img-top"
                     style="height:220px; object-fit:cover;"
                     alt="Property Image" />

                        <div class="card-body d-flex flex-column">

                            <!-- Property Name -->
                            <h5 class="fw-bold mb-1">
                                @property.PropertyName
                            </h5>

                            <!-- Property Type -->
                            <p class="text-muted mb-2">
                                @property.PropertyType
                            </p>

                            <!-- Location -->
                            <p class="mb-2">
                                <i class="bi bi-geo-alt"></i>
                                @property.Street,
                                @property.Suburb,
                                @property.City,
                                @property.Province
                            </p>

                            <!-- Stats -->
                            <div class="mb-3">

                                <span class="badge bg-primary me-2">
                                    Rooms: @property.TotalRooms
                                </span>

                                <span class="badge bg-dark">
                                    Listings: @property.TotalListings
                                </span>

                            </div>

                            <!-- Created -->
                            <small class="text-muted mb-3">
                                Added on @property.CreatedAt.ToString("dd MMM yyyy")
                            </small>

                            <!-- Buttons -->
                            <div class="mt-auto d-grid gap-2">

                                <a asp-controller="Listing"
                                   asp-action="CreateListing"
                                   asp-route-propertyId="@property.PropertyId"
                                   class="btn btn-success">
                                    Add Listing
                                </a>

                                <a asp-controller="Property"
                                   asp-action="PropertyDetails"
                                   asp-route-propertyId="@property.PropertyId"
                                   class="btn btn-outline-primary">
                                    View Property
                                </a>

                                <form asp-controller="Property" asp-action="DeleteProperty" method="post">
                                    <input type="hidden" name="propertyId" value="@property.PropertyId" />

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Are you sure you want to delete this property?')">
                                        Delete
                                    </button>
                                </form>

                            </div>

                        </div>

                    </div>

                </div>
                }

        </div>
    }

</div>