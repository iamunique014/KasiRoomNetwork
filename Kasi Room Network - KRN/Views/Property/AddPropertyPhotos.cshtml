@{
    ViewData["Title"] = "Add Photos";
    var propertyId = ViewBag.PropertyId;
}

@section styles
{
    <link rel="stylesheet" href="~/css/Property-details.css"/>
}

<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">

    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary rounded-circle p-1" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <p class="text-muted small mb-1">Step 2 of 2</p>
                <h1 class="h3 mb-0 fw-bold">Add Property Photos</h1>
            </div>
        </div>
        <p class="text-muted ms-1">Photos help people trust your property and get more views</p>
    </div>

    <!-- Success Messages -->
    @if (TempData["PhotoUploaded"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["PhotoUploaded"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Validation Summary -->
    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert" >
        <i class="bi bi-exclamation-circle me-2"></i>
        <strong>Please fix the errors below:</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <!-- Upload Card -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-cloud-upload me-2 text-primary"></i>
                Upload New Photo
            </h5>

            <form asp-action="AddPropertyPhotos" method="post" enctype="multipart/form-data" id="photoForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="propertyId" value="@propertyId" />

                <!-- Photo Count Info -->
                <div class="alert alert-info alert-dismissible rounded-2 mb-3" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    @if ((int)ViewBag.PhotoCount > 0)
                    {
                        <strong>@ViewBag.PhotoCount photo(s) uploaded </strong>
                        <small class="text-muted d-block mt-1">You can upload more photos or proceed to submit.</small>
                    }
                    else
                    {
                        <strong>No photos uploaded yet </strong>
                        <small class="text-muted d-block mt-1">Upload at least one photo to proceed.</small>
                    }
                </div>

                <!-- File Input -->
                <div class="mb-3">
                    <label for="photoFile" class="form-label fw-semibold small text-muted">Select Photo <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="file" 
                               class="form-control rounded-2 border-light bg-light" 
                               id="photoFile" 
                               name="photo" 
                               accept="image/*" 
                               required />
                    </div>
                    <small class="text-muted d-block mt-1">Supported formats: JPG, PNG, GIF (Max 5MB)</small>
                </div>

                <!-- Primary Photo Checkbox -->
                <div class="form-check form-switch mb-4 p-3 bg-light rounded-2">
                    <input class="form-check-input ms-0 me-2"
                           type="checkbox"
                           id="isPrimary"
                           name="isPrimary"
                           value="true" />
                    <label class="form-check-label fw-semibold small" for="isPrimary">
                        Set as Primary Photo
                    </label>
                    <small class="text-muted d-block mt-1 ms-4">This photo will show first when people search</small>
                </div>

                <!-- Upload Button -->
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-upload me-2"></i>Upload Photo
                </button>
            </form>
        </div>
    </div>

    <!-- Photos Gallery Section (if photos exist) -->
    @if ((int)ViewBag.PhotoCount > 0)
    {
        <div class="mb-4">
            <h5 class="fw-bold mb-3 text-dark">
                <i class="bi bi-grid-3x3 me-2 text-info"></i>
                Uploaded Photos (@ViewBag.PhotoCount)
            </h5>

            <!-- Note: In a full implementation, you would fetch and display uploaded photos here -->
            <!-- For now, we show a placeholder message -->
            <div class="alert alert-info rounded-2">
                <i class="bi bi-info-circle me-2"></i>
                Your photos have been uploaded successfully. You can upload more or proceed to submit your property.
            </div>
        </div>
    }

    <!-- Action Buttons -->
    <div class="d-grid gap-2 mb-4 d-md-flex gap-md-3">
        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i>Back
        </a>

        @if ((int)ViewBag.PhotoCount > 0)
        {
            <a asp-action="PropertySubmitted" 
               asp-route-id="@propertyId" 
               class="btn btn-success rounded-pill px-4 shadow-sm ms-auto">
                <i class="bi bi-check-circle me-2"></i>Finish & Submit
            </a>
        }
        else
        {
            <button class="btn btn-secondary rounded-pill px-4 ms-auto" 
                    disabled 
                    data-bs-toggle="tooltip" 
                    data-bs-placement="top" 
                    title="Upload at least one photo to submit your property">
                <i class="bi bi-check-circle me-2"></i>Finish & Submit
            </button>
        }
    </div>

</div>

@section Scripts {
    <script>
        // Initialize tooltips
        document.addEventListener('DOMContentLoaded', function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}
