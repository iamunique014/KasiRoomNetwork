@model KasiRoomNetwork.Common.ViewModel.Properties.CreatePropertyViewModel

@{
    ViewData["Title"] = "Create Property";
}

@section styles
{
    <link rel="stylesheet" href="~/css/Property-details.css"/>
}

<div class="container-fluid px-0 px-sm-3 py-3 py-sm-4">

    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary rounded-circle p-1" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="h3 mb-0 fw-bold">Create Property</h1>
        </div>
        <p class="text-muted ms-1">Fill in the details below to add your property.</p>
    </div>

    <form asp-action="CreateProperty" method="post">
        @Html.AntiForgeryToken()

        <!-- Validation Summary -->
        @if (ViewData.ModelState.IsValid == false)
        {
            <div class="alert alert-danger alert-dismissible fade show mx-3 mx-sm-0 mb-4 rounded-3 shadow-sm" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>
                <strong>Please fix the errors below:</strong>
                <div asp-validation-summary="ModelOnly" class="mt-2"></div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Property Details Card -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-dark">
                    <i class="bi bi-info-circle me-2 text-info"></i>
                    Property Details
                </h5>

                <div class="mb-3">
                    <label asp-for="PropertyType" class="form-label fw-semibold small text-muted">Property Type <span class="text-danger">*</span></label>
                    <input asp-for="PropertyType" 
                           class="form-control rounded-2 border-light bg-light" 
                           placeholder="e.g. Apartment, House, Commune" />
                    <span asp-validation-for="PropertyType" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PropertyName" class="form-label fw-semibold small text-muted">Property Name</label>
                    <input asp-for="PropertyName" 
                           class="form-control rounded-2 border-light bg-light" 
                           placeholder="e.g. Sunset Apartments, Downtown Rooms" />
                    <small class="text-muted d-block mt-1">Optional - helps you identify your property</small>
                    <span asp-validation-for="PropertyName" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-0">
                    <label asp-for="TotalRooms" class="form-label fw-semibold small text-muted">Total Rooms</label>
                    <input asp-for="TotalRooms" 
                           class="form-control rounded-2 border-light bg-light" 
                           min="0" 
                           type="number" />
                    <small class="text-muted d-block mt-1">Optional - total number of rooms in this property</small>
                    <span asp-validation-for="TotalRooms" class="text-danger small d-block mt-1"></span>
                </div>
            </div>
        </div>

        <!-- Address Card -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-dark">
                    <i class="bi bi-geo-alt-fill me-2 text-primary"></i>
                    Address
                </h5>

                <div class="mb-3">
                    <label asp-for="Street" class="form-label fw-semibold small text-muted">Street Address <span class="text-danger">*</span></label>
                    <input asp-for="Street" 
                           class="form-control rounded-2 border-light bg-light" 
                           placeholder="e.g. 123 Main Street" />
                    <span asp-validation-for="Street" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-12 col-sm-6">
                        <label asp-for="Suburb" class="form-label fw-semibold small text-muted">Suburb <span class="text-danger">*</span></label>
                        <input asp-for="Suburb" 
                               class="form-control rounded-2 border-light bg-light" 
                               placeholder="e.g. Downtown" />
                        <span asp-validation-for="Suburb" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="City" class="form-label fw-semibold small text-muted">City <span class="text-danger">*</span></label>
                        <input asp-for="City" 
                               class="form-control rounded-2 border-light bg-light" 
                               placeholder="e.g. Johannesburg" />
                        <span asp-validation-for="City" class="text-danger small d-block mt-1"></span>
                    </div>
                </div>

                <div class="mb-0">
                    <label asp-for="Province" class="form-label fw-semibold small text-muted">Province <span class="text-danger">*</span></label>
                    <input asp-for="Province" 
                           class="form-control rounded-2 border-light bg-light" 
                           placeholder="e.g. Gauteng" />
                    <span asp-validation-for="Province" class="text-danger small d-block mt-1"></span>
                </div>
            </div>
        </div>

        <!-- Amenities Card -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-dark">
                    <i class="bi bi-star-fill me-2 text-warning"></i>
                    Amenities
                </h5>

                <p class="text-muted small mb-3">Select amenities available at your property</p>

                @foreach (var categoryGroup in Model.Amenities.GroupBy(a => a.Category))
                {
                    <div class="mb-4">
                        <h6 class="fw-bold text-primary mb-2">@categoryGroup.Key</h6>

                        <div class="row g-2">
                            @foreach (var amenity in categoryGroup)
                            {
                                <div class="col-12 col-sm-6">
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedAmenityIds"
                                               value="@amenity.AmenityId"
                                               id="amenity_@amenity.AmenityId" />
                                        <label class="form-check-label fw-semibold small"
                                               for="amenity_@amenity.AmenityId">
                                            @amenity.Name
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="d-grid gap-2 mb-4 d-md-flex gap-md-3">
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-x-lg me-2"></i>Cancel
            </a>
            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-check-lg me-2"></i>Create Property
            </button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
