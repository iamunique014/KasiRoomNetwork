@model KasiRoomNetwork.Common.ViewModel.PostRoomWizard.PostRoomAmenitiesStepViewModel

@{
    ViewData["Title"] = "Post Room - Amenities";
}

<div class="container mt-4">
    <div class="mx-auto" style="max-width: 640px;">
        <p class="text-muted mb-2">Step 3 of 7</p>

        <h2 class="fw-bold">Amenities</h2>
        <p class="text-muted">Choose any amenities available at the property. You can continue without selecting any.</p>

        <form asp-action="Amenities" method="post">
            @Html.AntiForgeryToken()

            <div class="card mb-4">
                <div class="card-body">
                    @if (Model.Amenities.Any())
                    {
                        <div class="row g-3">
                            @foreach (var amenity in Model.Amenities)
                            {
                                var checkboxId = $"amenity-{amenity.AmenityId}";
                                <div class="col-12 col-sm-6">
                                    <input class="btn-check"
                                           type="checkbox"
                                           name="SelectedAmenityIds"
                                           id="@checkboxId"
                                           value="@amenity.AmenityId"
                                           checked="@(Model.SelectedAmenityIds.Contains(amenity.AmenityId))" />
                                    <label class="btn btn-outline-success w-100 py-3 text-start" for="@checkboxId">
                                        <span class="fw-semibold">@amenity.Name</span>
                                        @if (!string.IsNullOrWhiteSpace(amenity.Category))
                                        {
                                            <span class="d-block small text-muted">@amenity.Category</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="mb-0 text-muted">No amenities are available to select right now.</p>
                    }
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-lg">Continue to Photos</button>
                <a asp-action="Address" class="btn btn-outline-secondary btn-lg">Back</a>
            </div>
        </form>
    </div>
</div>
