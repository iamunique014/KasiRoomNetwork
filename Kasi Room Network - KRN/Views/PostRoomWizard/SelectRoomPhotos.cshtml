@model List<KasiRoomNetwork.Common.ViewModel.PostRoomWizard.PostRoomUploadedPhotoViewModel>

@{
    ViewData["Title"] = "Post Room - Select Room Photos";
}

<div class="container mt-4">
    <div class="mx-auto" style="max-width: 720px;">
        <p class="text-muted mb-2">Step 6 of 7</p>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4 text-center">
                <h2 class="fw-bold">Select Room Photos</h2>
                <p class="text-muted mb-4">Photo categorization is the next step. Your room details have been saved for this wizard session.</p>

                <div class="d-grid gap-2">
                    <a asp-action="RoomDetails" class="btn btn-outline-secondary btn-lg">Back to Room Details</a>
                </div>
            </div>
        </div>
    </div>
</div>
