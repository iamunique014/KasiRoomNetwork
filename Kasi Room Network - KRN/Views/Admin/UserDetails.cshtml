@model KasiRoomNetwork.Common.ViewModel.Admin.AdminUserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
}

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>User Details</h2>

        <a asp-action="UserManagement"
           class="btn btn-outline-secondary">
            Back to Users
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Account Information -->
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <h5 class="mb-0">Account Information @Model.FullName</h5>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <strong>Username</strong>
                        <div>@Model.UserName</div>
                    </div>

                    <div class="mb-3">
                        <strong>Email</strong>
                        <div>@Model.Email</div>
                    </div>

                    <div class="mb-3">
                        <strong>Phone Number</strong>
                        <div>@Model.PhoneNumber</div>
                    </div>

                    <div class="mb-3">
                        <strong>Role</strong>
                        <div>
                            <span class="badge bg-primary">
                                @Model.RoleName
                            </span>
                        </div>
                    </div>

                    <div>
                        <strong>Registered</strong>
                        <div>
                            @Model.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Status -->
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <h5 class="mb-0">Account Status</h5>
                </div>

                <div class="card-body">

                    @if (Model.IsBlocked)
                    {
                        <span class="badge bg-danger fs-6 mb-3">
                            Blocked
                        </span>

                        <p>
                            This user is currently unable to sign in.
                        </p>

                        @if (Model.LockoutEnd.HasValue)
                        {
                            <p class="text-muted">
                                Locked until:
                                @Model.LockoutEnd.Value.ToString("dd MMM yyyy")
                            </p>
                        }
                    }
                    else
                    {
                        <span class="badge bg-success fs-6 mb-3">
                            Active
                        </span>

                        <p>
                            User account is active.
                        </p>
                    }

                    <hr />

                    @if (Model.IsBlocked)
                    {
                        <form asp-action="UnblockUser"
                              method="post">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="id"
                                   value="@Model.UserId" />

                            <button type="submit"
                                    class="btn btn-success w-100">
                                Unblock User
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="BlockUser"
                              method="post">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="id"
                                   value="@Model.UserId" />

                            <button type="submit"
                                    class="btn btn-danger w-100"
                                    onclick="return confirm('Block this user?');">
                                Block User
                            </button>
                        </form>
                    }

                </div>
            </div>
        </div>

        <!-- Activity Summary -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Activity Summary</h5>
                </div>

                <div class="card-body">

                    <div class="row text-center">

                        <div class="col-md-4 mb-3">
                            <h3>@Model.PropertyCount</h3>
                            <p class="text-muted mb-0">
                                Properties
                            </p>
                        </div>

                        <div class="col-md-4 mb-3">
                            <h3>@Model.ListingCount</h3>
                            <p class="text-muted mb-0">
                                Listings
                            </p>
                        </div>

                        <div class="col-md-4 mb-3">
                            <h3>@Model.ConversationCount</h3>
                            <p class="text-muted mb-0">
                                Conversations
                            </p>
                        </div>

                    </div>

                </div>
            </div>
        </div>

    </div>

</div>