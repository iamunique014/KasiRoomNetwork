@model IEnumerable<KasiRoomNetwork.Common.ViewModel.Admin.UnverifiedListingViewModel>

@{
    ViewData["Title"] = "Unverified Listings";
}

<h2 class="mb-4">🛑 Unverified Listings</h2>

@await Html.PartialAsync("_AdminAlerts")

@if (!Model.Any())
{
    <div class="text-center py-5">
        <h4 class="text-success">🎉 All caught up!</h4>
        <p class="text-muted">
            There are no listings waiting for verification right now.
        </p>
    </div>
}

else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Title</th>
                <th>Location</th>
                <th>Price</th>
                <th>Submitted</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Title</strong></td>
                    <td>@item.Suburb, @item.City</td>
                    <td>R @item.Price</td>
                    <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="ReviewListing"
                           asp-route-id="@item.ListingId"
                           class="btn btn-sm btn-primary">
                            Review
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
